% --- 8. TABELAS AUXILIARES ---
% Todas usam tabularx: colunas X dividem o espaço restante automaticamente.

% \tabelaSimulacao{<caption>}{<label>}{<linhas>}
\newcommand{\tabelaSimulacao}[3]{%
  \begin{table}[H]
    \centering
    \caption{#1}\label{#2}
    \begin{tabularx}{\textwidth}{cXXXX}
      \toprule
      \textbf{(Caso)} & \textbf{Operação} & \textbf{Sinais de entrada} &
      \textbf{Resultado esperado} & \textbf{Resultado observado} \\
      \midrule
      #3
      \bottomrule
    \end{tabularx}
  \end{table}%
}

% \tabeladuas{<caption>}{<label>}{<col1>}{<col2>}{<linhas>}
\newcommand{\tabeladuas}[5]{%
  \begin{table}[H]
    \centering
    \caption{#1}\label{#2}
    \begin{tabularx}{\textwidth}{XX}
      \toprule
      \textbf{#3} & \textbf{#4} \\
      \midrule
      #5
      \bottomrule
    \end{tabularx}
  \end{table}%
}

% \tabelatres{<caption>}{<label>}{<col1>}{<col2>}{<col3>}{<linhas>}
\newcommand{\tabelatres}[6]{%
  \begin{table}[H]
    \centering
    \caption{#1}\label{#2}
    \begin{tabularx}{\textwidth}{XXX}
      \toprule
      \textbf{#3} & \textbf{#4} & \textbf{#5} \\
      \midrule
      #6
      \bottomrule
    \end{tabularx}
  \end{table}%
}

% --- 7. IMAGENS ---
\newcommand{\poliBrasao}{logospoli/logorobusto}
\newcommand{\poliFilet}{logospoli/polytechnique-filetlongrouge}
\newcommand{\poliBarraLogo}{logospoli/usp+polibarra}
\newcommand{\poliImgCabecalho}{logospoli/nome-colorido}

\newcommand{\MarcaAguaCapa}{%
  \AddToShipoutPictureBG*{%
    \AtPageCenter{%
      \put(0,20mm){\makebox(0,0){%
        {\transparent{0.1}\includegraphics[width=0.5\paperwidth,keepaspectratio]{\poliBrasao}}%
      }}%
    }%
  }%
}

% --- 8. CAPA ---
\renewcommand{\maketitle}{%
  \begin{titlepage}
    \MarcaAguaCapa
    \centering

    % Cabeçalho fixo via eso-pic (não desloca o conteúdo da página)
    \AddToShipoutPictureBG*{%
      \AtPageUpperLeft{%
        \put(\LenToUnit{0.5\paperwidth},\LenToUnit{-2cm}){%
          \makebox(0,0)[t]{%
            \begin{tabular}{c}
              \includegraphics[width=16cm]{\poliImgCabecalho} \\
              \fonteCapa \poliDepartamentoSalvo
            \end{tabular}%
          }%
        }%
      }%
    }

    \vspace*{3.5cm}

    \begin{minipage}[t][12cm][c]{\textwidth}
      \centering
      {\huge\fonteCapa\bfseries\color{azulpoli}\poliTituloSalvo\par}
      \ifthenelse{\boolean{temSubtitulo}}{%
        \vspace{1cm}%
        {\Large\color{azulpoli}\textbf{\poliSubtituloSalvo}\par}%
      }{}
    \end{minipage}

    \vspace{2cm}

    \includegraphics{\poliFilet}
    \vspace{0.2cm}

    \poliBlocoAutores

    \vspace{0.2cm}
    \includegraphics{\poliFilet}

    \vfill
    \ifthenelse{\equal{\poliDisciplinaSalva}{}}{}{%
      {\large\fonteCapa\color{azulpoli}\poliDisciplinaSalva\par}%
      \vspace{0.4cm}%
    }
    {\large\poliDataSalva\par}

  \end{titlepage}
  \clearpage
}

% --- 9. CABEÇALHO E RODAPÉ ---
\newlength{\alturaLogoHeader}
\setlength{\alturaLogoHeader}{10mm}

\newcommand{\poliHeaderTitulo}{%
  \fonteCapa\color{azulpoli}\poliTituloCurtoSalvo%
}
\newcommand{\poliHeaderLogo}{%
  \includegraphics[height=\alturaLogoHeader]{\poliBarraLogo}%
}

% Logo no lado interno, título no lado externo (padrão livro)
\newpagestyle{poliusp}{%
  \sethead[\poliHeaderLogo][][\poliHeaderTitulo]%  páginas pares
          {\poliHeaderTitulo}{}{\poliHeaderLogo}%  páginas ímpares
  \headrule
  \setfoot[][\fonteCapa\color{azulpoli}\thepage][]%  páginas pares
          {}{\fonteCapa\color{azulpoli}\thepage}{}%  páginas ímpares
}

% --- 10. FORMATAÇÃO DE SEÇÕES ---
\renewcommand{\contentsname}{Sumário}

\titleformat{\section}
  {\centering\fonteCapa\bfseries\Large}
  {\thesection}{0.8em}{}

% Mesmo estilo para seções sem número (\section*)
\titleformat{name=\section,numberless}
  {\centering\fonteCapa\bfseries\Large}
  {}{0em}{}

\titleformat{\subsection}
  {\raggedright\fonteCapa\mdseries\large}
  {\thesubsection}{0.8em}{}

\titlespacing*{\section}   {0pt}{2.5ex plus 0.8ex minus 0.4ex}{1.2ex}
\titlespacing*{\subsection}{0pt}{2.0ex plus 0.6ex minus 0.3ex}{0.8ex}

