% --- 3. VARIÁVEIS DE METADADOS ---
\newcommand{\poliTituloSalvo}{Titulo do Relatorio}
\newcommand{\poliTituloCurtoSalvo}{Titulo Curto}
\newcommand{\poliSubtituloSalvo}{}
\newcommand{\poliDisciplinaSalva}{}
\newcommand{\poliDepartamentoSalvo}{}
\newcommand{\poliAutoresLista}{}
\newcommand{\poliDataSalva}{\today}
\newboolean{temSubtitulo}\setboolean{temSubtitulo}{false}

\newcommand{\titulo}[2][]{%
  \renewcommand{\poliTituloSalvo}{#2}%
  \ifthenelse{\equal{#1}{}}{%
    \renewcommand{\poliTituloCurtoSalvo}{#2}%
  }{%
    \renewcommand{\poliTituloCurtoSalvo}{#1}%
  }%
}
\newcommand{\subtitulo}[1]{%
  \renewcommand{\poliSubtituloSalvo}{#1}%
  \setboolean{temSubtitulo}{true}%
}
\newcommand{\disciplina}[1]{\renewcommand{\poliDisciplinaSalva}{#1}}
\newcommand{\departamento}[1]{\renewcommand{\poliDepartamentoSalvo}{#1}}
\newcommand{\Autores}[1]{\renewcommand{\poliAutoresLista}{#1}}
\newcommand{\data}[1]{\renewcommand{\poliDataSalva}{#1}}

% --- 4. BLOCO DE AUTORES ---
\newcommand{\poliBlocoAutores}{%
  \begin{minipage}[t]{\textwidth}
    \centering\large
    \poliAutoresLista
  \end{minipage}%
}

% --- 5. SUMÁRIO LOCAL DE SEÇÃO ---
\newcommand{\gerarSumarioLocal}{%
  \begingroup
  \etocsettocdepth{subsection}
  \etocsetstyle{section}{}{}{}{}
  \etocsetstyle{subsection}
    {}
    {\leavevmode\leftskip 1.5em \noindent}
    {%
      \textbf{\etocnumber}\hspace{0.5em}%
      \etocname
      \nobreak
      \leaders\hbox to 0.5em{\hss.\hss}\hfill
      \nobreak
      \makebox[1.2em][r]{\textbf{\etocpage}}%
      \hspace{1.5em}%
      \par\vspace{5pt}%
    }
    {}
  \etocsettocstyle
    {%
      \begin{center}\begin{minipage}{0.85\textwidth}
      \noindent\textbf{Seções}
      \par\vspace{1pt}\hrule height 0.6pt\vspace{10pt}%
    }
    {%
      \vspace{5pt}\hrule height 0.6pt
      \end{minipage}\end{center}%
      \vspace{0.5cm}%
    }
  \localtableofcontents
  \endgroup
}

